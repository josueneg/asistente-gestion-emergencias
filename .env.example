# ============================================================
# Variables de entorno - Asistente IA COE Panamá
# ============================================================
# Copia este archivo a ".env" para pruebas locales del script
# de clima (scripts/weather-check.mjs). NUNCA subas el ".env"
# real al repositorio (ya está excluido en .gitignore).
#
# Estas mismas variables, para producción, se configuran como:
#   - "Secrets" del repositorio en GitHub (para el cron de clima)
#   - "Secrets" de las Edge Functions en Supabase
#     (comando: supabase secrets set NOMBRE=valor)
#
# Ver docs/SETUP.md para instrucciones detalladas de dónde
# obtener cada valor.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Groq (LLM de chat y redacción de alertas) ---
GROQ_API_KEY=tu-groq-api-key

# --- Google AI Studio (embeddings para RAG) ---
GEMINI_API_KEY=tu-gemini-api-key

# --- Secreto compartido entre el cron de GitHub Actions y la
#     Edge Function "weather-alert" (evita que cualquiera dispare
#     alertas falsas llamando a la función directamente) ---
WEATHER_CRON_SECRET=elige-una-frase-secreta-larga-y-unica
